# Secrets-only environment template.
# Copy to .env locally and keep all values empty in this tracked example.
# Do not add non-secret installation or strategy config here; use configs/*.yaml.

# Read-only API token for dashboard/mobile status access.
API_READ_TOKEN=

# Admin API token for privileged operations. Admin may satisfy read-only checks; read-only must never satisfy admin checks.
API_ADMIN_TOKEN=

# Limited device token used by clients to register/unregister push notification tokens.
API_DEVICE_TOKEN=

# Frontend/mobile copy of the limited device token for push-token registration only.
VITE_API_DEVICE_TOKEN=

# Limited token used only to synchronize alert configuration.
API_ALERTS_TOKEN=

# Frontend/mobile copy of the limited alert synchronization token.
VITE_API_ALERTS_TOKEN=

# Backend base URL per il build CI (in locale viene letta da configs/instance.yaml → frontend.backend_api_base_url).
# Impostare come GitHub secret VITE_BACKEND_API_BASE_URL solo per le build CI/CD.
# VITE_BACKEND_API_BASE_URL=

# Secret pepper for hashing stored API tokens or similar local credentials.
TOKEN_HASH_PEPPER=

# Database URL only when it embeds credentials or points to a managed secret-bearing database.
DATABASE_URL=

# CoinMarketCap API key.
CMC_API_KEY=

# Anthropic API key for the agent meta-controller.
ANTHROPIC_API_KEY=

# Trust Wallet Agent Kit access identifier.
TWAK_ACCESS_ID=

# Trust Wallet Agent Kit HMAC secret.
TWAK_HMAC_SECRET=

# Filesystem path to encrypted wallet key material. Treat paths to secret files as sensitive.
WALLET_ENCRYPTED_PRIVATE_KEY_PATH=

# Name of the environment variable or secret-manager key that provides the wallet passphrase.
WALLET_KEY_PASSPHRASE_ENV=

# Path to Firebase service account JSON. Treat paths to service-account files as sensitive.
FCM_CREDENTIALS_PATH=
